SHOPIFY_STORE_DOMAIN=starbuy.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_public_storefront_token
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=your_private_storefront_token
SHOPIFY_API_VERSION=2026-04
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=starbuy.myshopify.com

# Admin API (client credentials OAuth)
SHOPIFY_CLIENT_ID=your_admin_client_id
SHOPIFY_CLIENT_SECRET=your_admin_client_secret

# Admin panel auth
ADMIN_CHAT_PASSWORD=your_secure_admin_password
# JWT secret for signing admin tokens (min 32 chars recommended)
# Falls back to ADMIN_CHAT_PASSWORD if not set (backwards compat)
ADMIN_JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key
