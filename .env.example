# ============================================================
# STARBUY — Environment Variables
# ============================================================
# Copy this file to .env.local (dev) or .env.production (VPS)
# and fill in your actual values.
#
# NEVER commit .env.local or .env.production to git!
# ============================================================

# ─── Shopify Store ──────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2026-04

# ─── Shopify Admin API (Client Credentials OAuth) ──────────
SHOPIFY_CLIENT_ID=your-client-id
SHOPIFY_CLIENT_SECRET=your-client-secret

# ─── Shopify Storefront API ────────────────────────────────
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-token
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=your-private-token

# ─── Shopify Webhooks ──────────────────────────────────────
# Dedicated webhook signing secret (optional — falls back to CLIENT_SECRET)
# Get this from Shopify Admin > Settings > Notifications > Webhooks
SHOPIFY_WEBHOOK_SECRET=

# ─── Admin Panel Auth ──────────────────────────────────────
# Password for the /admin login page (hashed to JWT on login)
ADMIN_CHAT_PASSWORD=change-me-to-something-strong

# ─── AI Providers (at least one required for chat) ─────────
# Claude (Anthropic) — recommended for best results
ANTHROPIC_API_KEY=
# OpenAI (GPT-4o)
OPENAI_API_KEY=
# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── Public Variables (safe — exposed to browser) ──────────
# These are baked into the JS bundle at build time
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_API_VERSION=2026-04
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-token
NEXT_PUBLIC_SITE_URL=https://starbuyevolucion.com

# ─── Analytics (optional) ──────────────────────────────────
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=
# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=
