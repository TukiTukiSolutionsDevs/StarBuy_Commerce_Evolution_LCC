# ============================================================
# StarBuy Production Environment Variables
# ============================================================
# Copy to .env.production on your VPS and fill in real values.
# NEVER commit actual secrets to git.
#
# NEXT_PUBLIC_* → Baked into JS at BUILD TIME (Docker build args)
# Server-only   → Available at RUNTIME (docker-compose env_file)
# ============================================================

# ─── Shopify Store ──────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=starbuy-78634.myshopify.com
SHOPIFY_API_VERSION=2026-04

# ─── Shopify Admin API (OAuth — auto-renew 24h token) ──────
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# ─── Shopify Storefront API ────────────────────────────────
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_public_storefront_token
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=your_private_storefront_token

# ─── Admin Panel Auth ──────────────────────────────────────
ADMIN_CHAT_PASSWORD=your_secure_admin_password
# JWT secret for signing admin tokens (min 32 chars, use a strong random value)
# Falls back to ADMIN_CHAT_PASSWORD if not set (backwards compat)
ADMIN_JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# ─── AI Providers (add keys to enable) ─────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── Public (browser-safe, read-only) ──────────────────────
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=starbuy-78634.myshopify.com
NEXT_PUBLIC_SHOPIFY_API_VERSION=2026-04
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_public_storefront_token

# ─── VPS Deploy (GitHub Actions Secrets) ───────────────────
# VPS_HOST=149.34.48.16
# VPS_USER=deploy
# VPS_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----...
